#!/usr/bin/env bash
# dgc — Dual-Graph launcher for Claude Code
#
# Usage:
#   dgc                          # scan current directory, start claude
#   dgc /path/to/project         # scan given project, start claude
#   dgc /path/to/project "task"  # scan and start with a prompt

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

exec "$SCRIPT_DIR/dual_graph_launch.sh" claude "$@"
